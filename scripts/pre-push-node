#!/bin/sh
# Pre-push hook for Node.js projects
# Runs tests before allowing push

cd "$(git rev-parse --show-toplevel)" || exit 1

# Skip if no package.json - not a Node project
if [ ! -f package.json ]; then
  echo "[INFO] No package.json found - skipping pre-push tests"
  exit 0
fi

# Detect whether package.json defines a 'test' script.
# Surface read/parse errors (rc=2) instead of masking them.
node -e "try { const p = require('./package.json'); process.exit(p.scripts && p.scripts.test ? 0 : 1); } catch (e) { console.error('[ERROR] Failed to read package.json:', e.message); process.exit(2); }"
rc=$?

if [ $rc -eq 2 ]; then
  echo "[ERROR] package.json is malformed - aborting push"
  exit 1
fi

if [ $rc -ne 0 ]; then
  echo "[INFO] No 'test' script in package.json - skipping pre-push tests (CI will validate)"
  exit 0
fi

echo "[INFO] Running pre-push tests..."
npm test
exit $?
